# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nosexyproject
.noseids
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
vts/
.hypothesis/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
#   For a library or package, you might want to ignore these files since the PII redaction tool is standalone
.python-version

# pipenv
#   According to pypa/pipenv#1013, pipenv should not ignore Pipfile.lock in general, but we aren't using pipenv.

# poetry
#   Poetry uses pyproject.toml and poetry.lock, which should be committed.

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDEs
.vscode/
.idea/

# Project specific: Ignore inputs and outputs but keep the directory via .gitkeep
input/*
!input/.gitkeep
output/*
!output/.gitkeep
evaluation/*
!evaluation/.gitkeep
